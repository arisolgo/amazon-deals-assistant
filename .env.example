# ─────────────────────────────────────────────
#  Amazon Deals Assistant — Environment Config
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────

# ── Amazon ────────────────────────────────────
AMAZON_DEALS_URL=https://www.amazon.com/deals
AMAZON_REFERRAL_TAG=YOUR_ASSOCIATE_TAG-20
AMAZON_MAX_DEALS=20

# ── Notify channel: console | email | slack | webhook ──
NOTIFY_CHANNEL=console
NOTIFY_EMAIL=
NOTIFY_SLACK_WEBHOOK=
NOTIFY_WEBHOOK_URL=

# ── Schedule ──────────────────────────────────
SCHEDULE_START_AT=09:00
SCHEDULE_INTERVAL_MINUTES=30
SCHEDULE_MAX_RUNS=5

# ── Email / SMTP (required only when NOTIFY_CHANNEL=email) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=yourapppassword
SMTP_TO=you@gmail.com
